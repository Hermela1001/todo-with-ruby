<div class="card bg-dark p-4 rounded shadow-sm">
  <h1 class="text-center mb-4">To Do App</h1>

  <div class="d-flex mb-3">
    <%= link_to "Add New Todo", new_todo_path, class: "btn btn-primary me-2" %>
    <%= link_to "All", todos_path, class: "btn btn-outline-light me-2 #{'active' if @filter.blank?}" %>
    <%= link_to "Completed", todos_path(filter: 'completed'), class: "btn btn-outline-success me-2 #{'active' if @filter == 'completed'}" %>
    <%= link_to "Incomplete", todos_path(filter: 'incomplete'), class: "btn btn-outline-warning #{'active' if @filter == 'incomplete'}" %>
  </div>

  <% if @todos.any? %>
    <table class="table table-striped table-dark">
      <thead>
        <tr>
          <th>No.</th>
          <th>Todo Item</th>
          <th>Due Date</th>
          <th>Tag</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @todos.each_with_index do |todo, index| %>
          <tr>
            <td><%= index + 1 %></td>
            <td><%= todo.title %></td>
            <td><%= todo.due_date ? todo.due_date.strftime("%Y-%m-%d") : "-" %></td>
            <td>
              <% if todo.tag.present? %>
                <span class="badge bg-info text-dark"><%= todo.tag %></span>
              <% else %>
                <span class="text-muted">-</span>
              <% end %>
            </td>
            <td>
              <% if todo.completed %>
                <span class="badge bg-success">Finished</span>
              <% else %>
                <span class="badge bg-warning text-dark">In progress</span>
              <% end %>
            </td>
            <td>
              <%= link_to "Delete", todo, method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-sm btn-delete mb-1" %>
              <%= link_to "Finished", toggle_completed_todo_path(todo), method: :patch, class: "btn btn-sm btn-finished" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p>No todos found. <%= link_to "Add one now!", new_todo_path %></p>
  <% end %>
</div>
