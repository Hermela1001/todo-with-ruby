<%= form_with(model: todo, local: true, class: "needs-validation") do |form| %>
  <div class="mb-3">
    <%= form.label :title, class: "form-label fw-semibold" %>
    <%= form.text_field :title, class: "form-control", required: true, autofocus: true %>
  </div>

  <div class="mb-3">
    <%= form.label :description, class: "form-label fw-semibold" %>
    <%= form.text_area :description, rows: 4, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :due_date, class: "form-label fw-semibold" %>
    <%= form.date_field :due_date, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :tag, class: "form-label fw-semibold" %>
    <%= form.text_field :tag, class: "form-control" %>
  </div>

  <div class="form-check mb-4">
    <%= form.check_box :completed, class: "form-check-input", id: "todo_completed" %>
    <%= form.label :completed, class: "form-check-label", for: "todo_completed" %>
  </div>

  <div class="d-flex justify-content-between">
    <%= form.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", todos_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
