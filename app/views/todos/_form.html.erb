<%= form_with(model: todo, local: true) do |form| %>
  <% if todo.errors.any? %>
    <div class="alert alert-danger">
      <h4><%= pluralize(todo.errors.count, "error") %> prohibited this todo from being saved:</h4>
      <ul>
        <% todo.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :title, class: "form-label" %>
    <%= form.text_field :title, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :description, class: "form-label" %>
    <%= form.text_area :description, rows: 3, class: "form-control" %>
  </div>
  
  <div class="form-check mb-3">
    <%= form.check_box :completed, class: "form-check-input" %>
    <%= form.label :completed, class: "form-check-label" %>
  </div>

  <%= form.submit class: "btn btn-primary" %>
<% end %>
<%= form_with(model: todo, local: true) do |form| %>
<div class="mb-3">
  <%= form.label :tag, "Tag / Category" %>
  <%= form.text_field :tag, class: "form-control", placeholder: "e.g. Work, Personal, Urgent" %>
</div>
  <div class="mb-3">
    <%= form.label :title %>
    <%= form.text_field :title, class: "form-control" %>
  </div>

  <!-- Due Date -->
  <div class="mb-3">
    <%= form.label :due_date, "Due Date" %>
    <%= form.date_field :due_date, class: "form-control" %>
  </div>

  <!-- Priority -->
  <div class="mb-3">
    <%= form.label :priority, "Priority" %>
    <%= form.select :priority, [["High", "high"], ["Medium", "medium"], ["Low", "low"]],
        { include_blank: "Select Priority" },
        class: "form-select" %>
  </div>

  <div class="actions">
    <%= form.submit class: "btn btn-primary" %>
  </div>
<% end %>
